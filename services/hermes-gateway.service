[Unit]
Description=Hermes Agent Gateway - Messaging Platform Integration
After=network-online.target
Wants=network-online.target
StartLimitIntervalSec=600
StartLimitBurst=5

[Service]
Type=simple
User=administrator
Group=administrator
ExecStart=/home/administrator/.hermes/hermes-agent/venv/bin/python -m hermes_cli.main gateway run --replace
WorkingDirectory=/home/administrator/.hermes/hermes-agent
Environment="HOME=/home/administrator"
Environment="USER=administrator"
Environment="LOGNAME=administrator"
Environment="PATH=/home/administrator/.hermes/hermes-agent/venv/bin:/home/administrator/.hermes/hermes-agent/node_modules/.bin:/home/administrator/.local/bin:/usr/local/sbin:/usr/local/bin:/usr/sbin:/usr/bin:/sbin:/bin"
Environment="VIRTUAL_ENV=/home/administrator/.hermes/hermes-agent/venv"
Environment="HERMES_HOME=/home/administrator/.hermes"
Restart=on-failure
RestartSec=30
RestartForceExitStatus=75
KillMode=mixed
KillSignal=SIGTERM
ExecReload=/bin/kill -USR1 $MAINPID
TimeoutStopSec=60
StandardOutput=journal
StandardError=journal

[Install]
WantedBy=multi-user.target
